{
  "name": "specialist-expo-app",
  "main": "expo-router/entry",
  "version": "2.0.0",
  "scripts": {
    "start": "npm --silent run _start",
    "_start": "node ./scripts/start-clear.mjs",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "lint:hooks": "node ./scripts/lint-react-hooks.mjs",
    "doctor": "bunx expo-doctor",
    "verify:eas-root": "node ./scripts/verify-eas-root.mjs",
    "build:ios": "npm run verify:eas-root && npm run doctor && npm run lint:hooks && bunx eas-cli build --profile production --platform ios",
    "build:ios:submit": "npm run verify:eas-root && npm run doctor && npm run lint:hooks && bunx eas-cli build --profile production --platform ios --auto-submit",
    "submit:ios": "bunx eas-cli submit --profile production --platform ios --latest"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.16",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.8",
    "expo-image": "~55.0.11",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-quick-actions": "6.0.1",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-webrtc": "^124.0.5",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": []
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": ["react-native-webrtc"]
      }
    }
  },
  "private": true
}
